{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Starfield",
  "version": "1.1.2",
  "identifier": "com.stardust.starfield",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Starfield",
        "width": 1100,
        "height": 760,
        "minWidth": 840,
        "minHeight": 580,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/as9284/project-starfield/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzQUJCQjRBQzhBMzI4NkQKUldSdEtLUElTcnVyVTBRNnNWK0JwWGhOSGNNKzBHWldHRzJhZEluK3BnVHBUYVg4TnJEK0JvYmsK"
    }
  }
}
